{
  "name": "artifactory-helper",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "upload",
    "download"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w upload -w download",
    "test": "vitest run --coverage",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "all": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.5",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
